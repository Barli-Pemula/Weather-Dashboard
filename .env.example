# Weather Dashboard Environment Variables
# Copy this file to .env.local and update with your values

# Open-Meteo API (Free, no authentication required)
# The API is used to fetch real-time weather data
NEXT_PUBLIC_WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Default coordinates for weather data (Jakarta, Indonesia)
# You can change these to display weather for different locations
NEXT_PUBLIC_DEFAULT_LATITUDE=-6.2088
NEXT_PUBLIC_DEFAULT_LONGITUDE=106.8456

# Next.js Environment
NEXT_PUBLIC_APP_NAME=Weather Dashboard
NODE_ENV=development
